# ============ AI 模型配置 ============
# 必填：选择以下任一方式配置 AI 模型

# 方式一：DeepSeek 官方 API（推荐，便宜）
# 注册地址：https://platform.deepseek.com
AI_API_KEY=sk-your-deepseek-key-here
AI_API_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# 方式二：通义千问（阿里云）
# AI_API_KEY=sk-your-qwen-key-here
# AI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus

# 方式三：Ollama 本地模型（免费，无需 API Key）
# 安装：https://ollama.com/download
# 运行：ollama pull qwen3:8b
# AI_API_KEY=
# AI_API_BASE_URL=http://localhost:11434/v1
# AI_MODEL=qwen3:8b

# ============ 服务配置 ============
PORT=3003
NODE_ENV=production

# JWT 密钥（请更换为随机字符串）
JWT_SECRET=change-this-to-a-random-string